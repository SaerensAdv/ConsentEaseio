{
  "name": "clickup-automation",
  "version": "1.0.0",
  "description": "Automated ClickUp task management with git integration",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "build": "tsc",
    "install-hooks": "tsx -e \"require('./src').installGitHooks()\"",
    "uninstall-hooks": "tsx -e \"require('./src').uninstallGitHooks()\"",
    "process-queue": "tsx -e \"require('./src').processQueue().then(console.log)\"",
    "status": "tsx -e \"require('./src').queue.getUnprocessedCount().then(n => console.log('Pending:', n))\""
  },
  "keywords": ["clickup", "automation", "task-management", "git-hooks"],
  "author": "",
  "license": "MIT",
  "peerDependencies": {
    "tsx": "^4.0.0"
  }
}
