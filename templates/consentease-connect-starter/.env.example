# Copy to .env (or add these in the Secrets pane: Tools → Secrets).

# Required: your ConsentEase API key.
# Create one in the dashboard under Settings → API Keys (shown once).
CONSENTEASE_API_KEY=ce_live_your_key_here

# Optional: only set this to target a local/dev server.
# Defaults to the live production API (https://consentease.io).
# CONSENTEASE_API_URL=http://localhost:5000
